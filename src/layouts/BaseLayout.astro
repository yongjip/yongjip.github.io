---
import "../styles/global.css";
import CloudflareAnalytics from "../components/CloudflareAnalytics.astro";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import { SITE_OWNER } from "../data/site";
import { getSeoLocale, SITE_OG_IMAGE_URL, type JsonLdNode } from "../lib/seo";

interface Alternate {
  hreflang: string;
  href: string;
}

interface Props {
  lang: "en" | "ko";
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: "website" | "article";
  alternates?: Alternate[];
  schema?: JsonLdNode[];
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}

const {
  lang,
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogType = "website",
  alternates = [],
  schema = [],
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props;

const ogImage = SITE_OG_IMAGE_URL;
const seoLocale = getSeoLocale(lang);
const canonicalAlternates = alternates.filter((alternate) => alternate.hreflang !== "x-default");
const xDefaultHref =
  alternates.find((alternate) => alternate.hreflang === "x-default")?.href ??
  canonicalAlternates.find((alternate) => alternate.hreflang === "en")?.href;
const schemaPayload =
  schema.length === 0
    ? undefined
    : schema.length === 1
      ? { "@context": "https://schema.org", ...schema[0] }
      : { "@context": "https://schema.org", "@graph": schema };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_OWNER[lang]} />
    <meta property="og:locale" content={seoLocale.ogLocale} />
    <meta property="og:locale:alternate" content={seoLocale.alternateOgLocale} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
    {canonicalAlternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
    ))}
    {xDefaultHref && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}
    {schemaPayload && <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaPayload)} />}
    <GoogleAnalytics />
    <slot name="head" />
  </head>
  <body class={Astro.url.pathname === "/" || Astro.url.pathname === "/ko/" ? "home-page" : "detail-page"}>
    <a class="skip-link" href="#main-content">{lang === "ko" ? "본문으로 건너뛰기" : "Skip to content"}</a>
    <slot />
    <CloudflareAnalytics />
  </body>
</html>
