---
import "../styles/global.css";

interface Alternate {
  hreflang: string;
  href: string;
}

interface Props {
  lang: "en" | "ko";
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: "website" | "article";
  alternates?: Alternate[];
}

const {
  lang,
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogType = "website",
  alternates = [],
} = Astro.props;

const ogImage = "https://yongjip.github.io/resources/og/portfolio-cover.png";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {lang === "ko" ? (
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=IBM+Plex+Sans+KR:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    ) : (
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    )}
    <slot name="head" />
  </head>
  <body class={Astro.url.pathname === "/" || Astro.url.pathname === "/ko/" ? "home-page" : "detail-page"}>
    <slot />
  </body>
</html>
