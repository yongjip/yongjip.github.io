---
import { PROFILE_LINKS, type Lang } from "../data/site";
import { getHomePath, getIndexPath } from "../lib/routes";
import LanguageSwitch from "./LanguageSwitch.astro";

interface Props {
  lang: Lang;
  enHref: string;
  koHref: string;
}

const { lang, enHref, koHref } = Astro.props;
const pathname = Astro.url.pathname;
const homeHref = getHomePath(lang);
const workHref = getIndexPath("work", lang);
const methodsHref = getIndexPath("method", lang);
const isHome = pathname === homeHref;
const isWork = pathname === workHref || pathname.startsWith(workHref);
const isMethods = pathname === methodsHref || pathname.startsWith(methodsHref);
---

<header class={`site-header ${isHome ? "site-header-home" : "site-header-detail"}`}>
  <span class="brand">Yongjip Kim</span>
  <div class="header-actions">
    <nav class="top-nav" aria-label="Primary">
      <a class={`nav-link ${isHome ? "is-active" : ""}`.trim()} href={homeHref}>
        {lang === "ko" ? "Home" : "Home"}
      </a>
      <a class={`nav-link ${isWork ? "is-active" : ""}`.trim()} href={workHref}>Work</a>
      <a class={`nav-link ${isMethods ? "is-active" : ""}`.trim()} href={methodsHref}>Methods</a>
    </nav>
    <div class="profile-links" aria-label="Profiles">
      <a
        class="icon-link"
        href={PROFILE_LINKS.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={lang === "ko" ? "LinkedIn 프로필" : "LinkedIn profile"}
        title={lang === "ko" ? "LinkedIn 프로필" : "LinkedIn profile"}
      >
        <svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
      <a
        class="icon-link"
        href={PROFILE_LINKS.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={lang === "ko" ? "GitHub 프로필" : "GitHub profile"}
        title={lang === "ko" ? "GitHub 프로필" : "GitHub profile"}
      >
        <svg class="icon-svg" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3.26-.36 6.68-1.6 6.68-7.2A5.6 5.6 0 0 0 19 3.77 5.07 5.07 0 0 0 18.91 1S17.73.65 15 2.48a13.38 13.38 0 0 0-6 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 3.77a5.6 5.6 0 0 0-1.69 3.78c0 5.56 3.42 6.84 6.68 7.2A4.8 4.8 0 0 0 9 18v4"></path>
        </svg>
      </a>
    </div>
    <LanguageSwitch lang={lang} enHref={enHref} koHref={koHref} />
  </div>
</header>
