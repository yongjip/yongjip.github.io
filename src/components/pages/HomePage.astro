---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BriefList from "../BriefList.astro";
import MethodList from "../MethodList.astro";
import SiteFooter from "../SiteFooter.astro";
import SiteHeader from "../SiteHeader.astro";
import WorkCard from "../WorkCard.astro";
import { EXPERIENCE_ITEMS, HOME_COPY, SHARED_UI_COPY } from "../../data/site";
import { getFeaturedWork, getMethodPreview } from "../../lib/content";
import { getHomePath, getIndexPath, toAbsoluteUrl } from "../../lib/routes";
import { buildHomeSchemas } from "../../lib/seo";

interface Props {
  lang: "en" | "ko";
}

const { lang } = Astro.props;
const featuredWork = await getFeaturedWork(lang);
const methods = await getMethodPreview(lang, 1);
const copy = HOME_COPY[lang];
const canonical = toAbsoluteUrl(getHomePath(lang));
const metadata =
  lang === "ko"
    ? {
        title: "김용집 | 데이터 시스템 포트폴리오",
        description: "김용집은 실제 비즈니스 운영을 위한 데이터 플랫폼, 분석 워크플로우, AI 기반 내부 도구를 구축합니다.",
        ogTitle: "AI로 데이터 시스템을 구축합니다",
        ogDescription: "김용집은 실제 비즈니스 운영을 위한 데이터 플랫폼, 분석 워크플로우, AI 기반 내부 도구를 구축합니다.",
      }
    : {
        title: "Yongjip Kim | Data Systems Portfolio",
        description:
          "Yongjip Kim builds data platforms, analytics workflows, and AI-assisted internal tools for real business operations.",
        ogTitle: "Building Data Systems with AI",
        ogDescription: "Yongjip Kim builds data platforms, analytics workflows, and practical internal systems with AI.",
      };
---

<BaseLayout
  lang={lang}
  title={metadata.title}
  description={metadata.description}
  canonical={canonical}
  ogTitle={metadata.ogTitle}
  ogDescription={metadata.ogDescription}
  alternates={[
    { hreflang: "en", href: toAbsoluteUrl("/") },
    { hreflang: "ko", href: toAbsoluteUrl("/ko/") },
  ]}
  schema={buildHomeSchemas(lang)}
>
  <main id="main-content" class="site-shell site-shell-home home-front-page">
    <SiteHeader lang={lang} enHref="/" koHref="/ko/" />

    <section class="hero hero-home">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.title}</h1>
      <p class="hero-copy">{copy.description}</p>
    </section>

    <section class="section section-work" id="selected-work">
      <div class="section-heading section-heading-home">
        <p class="section-label">Work</p>
        <h2>{copy.featuredHeading}</h2>
      </div>
      <div class="section-group">
        <div class="work-list work-list-archive">
          {featuredWork.map((entry) => <WorkCard entry={entry} mode="archive" />)}
        </div>
        <a class="text-link section-cta" href={getIndexPath("work", lang)}>{SHARED_UI_COPY.archiveCtas.work}</a>
      </div>
    </section>

    <section class="section section-list">
      <div class="section-heading section-heading-home">
        <p class="section-label">{lang === "ko" ? "경력" : "Experience"}</p>
        <h2>{copy.experienceHeading}</h2>
      </div>
      <div class="section-group">
        <BriefList items={EXPERIENCE_ITEMS[lang]} />
      </div>
    </section>

    <section class="section section-list section-methods">
      <div class="section-heading section-heading-home">
        <p class="section-label">{lang === "ko" ? "방법론" : "Methods"}</p>
        <h2>{copy.methodsHeading}</h2>
      </div>
      <div class="section-group">
        <p class="section-intro">{copy.methodsIntro}</p>
        <MethodList entries={methods} preview />
        <a class="text-link section-cta" href={getIndexPath("method", lang)}>{SHARED_UI_COPY.archiveCtas.methods}</a>
      </div>
    </section>

    <SiteFooter text={copy.footer} />
  </main>
</BaseLayout>

