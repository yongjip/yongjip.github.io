---
import type { CollectionEntry } from "astro:content";
import { getEntryPath } from "../lib/routes";

interface Props {
  entry: CollectionEntry<"work"> | CollectionEntry<"methods">;
  mode?: "preview" | "archive";
}

const { entry } = Astro.props;
const href = getEntryPath(entry.data.kind, entry.data.id, entry.data.lang);
const kicker = entry.data.kind === "work"
  ? entry.data.lang === "ko"
    ? "케이스 스터디"
    : "Case study"
  : entry.data.lang === "ko"
    ? "방법론"
    : "Method";
const meta =
  entry.data.kind === "work"
    ? entry.data.resultSummary
    : entry.data.lang === "ko"
      ? `형식: ${entry.data.format}`
      : `Format: ${entry.data.format}`;
const cardClass = "work-card work-card-archive";
---

<article class={cardClass}>
  <div class="work-card-main">
    <p class="work-kicker">{kicker}</p>
    <h3>
      <a class="work-title-link" href={href}>{entry.data.shortTitle}</a>
    </h3>
    <p class="work-summary">{entry.data.description}</p>
    <div class="work-card-inline-meta">
      <p class="work-proof">{meta}</p>
    </div>
  </div>
</article>
