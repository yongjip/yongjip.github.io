---
import { SHARED_UI_COPY } from "../data/site";

interface Props {
  enHref: string;
  koHref: string;
  lang: "en" | "ko";
}

const { enHref, koHref, lang } = Astro.props;
---

<nav class="lang-switch" aria-label={SHARED_UI_COPY.language.label}>
  <a class={lang === "en" ? "is-active" : undefined} href={enHref} lang="en" aria-current={lang === "en" ? "page" : undefined}>{SHARED_UI_COPY.language.en}</a>
  <a class={lang === "ko" ? "is-active" : undefined} href={koHref} lang="ko" aria-current={lang === "ko" ? "page" : undefined}>{SHARED_UI_COPY.language.ko}</a>
</nav>
