---
interface Fact {
  label: string;
  value: string;
}

interface Props {
  label: string;
  title: string;
  summary: string;
  dateFacts: Fact[];
  facts: Fact[];
}

const { label, title, summary, dateFacts, facts } = Astro.props;
const factClass = facts.length === 1 ? "article-facts article-facts-single" : "article-facts";
---

<section class="article-header">
  <p class="eyebrow">{label}</p>
  <h1>{title}</h1>
  <p class="article-summary">{summary}</p>
  <div class="article-date-line" aria-label="Article dates">
    {dateFacts.map((fact) => (
      <span class="article-date-item">
        <span class="article-date-label">{fact.label}</span>
        <span class="article-date-value">{fact.value}</span>
      </span>
    ))}
  </div>
  <div class={factClass}>
    {facts.map((fact) => (
      <article class="article-fact">
        <p class="article-fact-label">{fact.label}</p>
        <p class="article-fact-value">{fact.value}</p>
      </article>
    ))}
  </div>
</section>
