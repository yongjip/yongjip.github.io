---
interface Props {
  label: string;
  value: string;
  description: string;
  class?: string;
}

const { label, value, description, class: className } = Astro.props;
const classes = ["metric-item", className ?? ""].filter(Boolean).join(" ");
---

<article class={classes}>
  <p class="metric-label">{label}</p>
  <span class="metric-value">{value}</span>
  <p>{description}</p>
</article>

