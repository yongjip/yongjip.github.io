---
import type { CollectionEntry } from "astro:content";
import { getEntryPath } from "../lib/routes";

interface Props {
  entries: Array<CollectionEntry<"work"> | CollectionEntry<"methods">>;
  lang: "en" | "ko";
}

const { entries, lang } = Astro.props;
---

<section class="detail-section">
  <p class="section-label">{lang === "ko" ? "관련 작업" : "Related work"}</p>
  <h2>{lang === "ko" ? "포트폴리오의 다른 작업" : "Other work in the portfolio"}</h2>
  <div class="related-list">
    {entries.map((entry) => (
      <article class="related-item">
        <a class="related-title" href={getEntryPath(entry.data.kind, entry.data.id, entry.data.lang)}>
          {entry.data.shortTitle}
        </a>
        <p>{entry.data.description}</p>
      </article>
    ))}
  </div>
</section>
