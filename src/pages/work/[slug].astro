---
import { render, getCollection } from "astro:content";
import DetailPageLayout from "../../components/DetailPageLayout.astro";
import { getEntryPath, getIndexPath, getLanguagePartnerPath, toAbsoluteUrl } from "../../lib/routes";

export async function getStaticPaths() {
  const entries = await getCollection("work", ({ data }) => data.lang === "en");
  return entries.map((entry) => ({
    params: { slug: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = "en";
---

<DetailPageLayout
  entry={entry}
  lang={lang}
  enHref={getEntryPath(entry.data.kind, entry.data.id, "en")}
  koHref={getLanguagePartnerPath(entry)}
  backHref={getIndexPath("work", lang)}
  alternates={[
    { hreflang: "en", href: toAbsoluteUrl(getEntryPath(entry.data.kind, entry.data.id, "en")) },
    { hreflang: "ko", href: toAbsoluteUrl(getLanguagePartnerPath(entry)) },
  ]}
>
  <Content />
</DetailPageLayout>
