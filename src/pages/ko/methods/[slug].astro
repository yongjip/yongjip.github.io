---
import { render, getCollection } from "astro:content";
import DetailPageLayout from "../../../components/DetailPageLayout.astro";
import { getEntryPath, getIndexPath, getLanguagePartnerPath, toAbsoluteUrl } from "../../../lib/routes";

export async function getStaticPaths() {
  const entries = await getCollection("methods", ({ data }) => data.lang === "ko");
  return entries.map((entry) => ({
    params: { slug: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = "ko";
---

<DetailPageLayout
  entry={entry}
  lang={lang}
  enHref={getLanguagePartnerPath(entry)}
  koHref={getEntryPath(entry.data.kind, entry.data.id, "ko")}
  backHref={getIndexPath("method", lang)}
  alternates={[
    { hreflang: "en", href: toAbsoluteUrl(getLanguagePartnerPath(entry)) },
    { hreflang: "ko", href: toAbsoluteUrl(getEntryPath(entry.data.kind, entry.data.id, "ko")) },
  ]}
>
  <Content />
</DetailPageLayout>
