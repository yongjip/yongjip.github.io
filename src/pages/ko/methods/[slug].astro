---
import { render, getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import ArticleHeader from "../../../components/ArticleHeader.astro";
import RelatedWork from "../../../components/RelatedWork.astro";
import { getRelatedEntries } from "../../../lib/content";
import { getEntryPath, getIndexPath, getLanguagePartnerPath, getPageLabel, toAbsoluteUrl } from "../../../lib/routes";

export async function getStaticPaths() {
  const entries = await getCollection("methods", ({ data }) => data.lang === "ko");
  return entries.map((entry) => ({
    params: { slug: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const related = await getRelatedEntries(entry);
const lang = "ko";
---

<BaseLayout
  lang={lang}
  title={`${entry.data.title} | 김용집`}
  description={entry.data.ogDescription ?? entry.data.description}
  canonical={toAbsoluteUrl(getEntryPath(entry.data.kind, entry.data.id, lang))}
  ogTitle={entry.data.ogTitle ?? entry.data.title}
  ogDescription={entry.data.ogDescription ?? entry.data.description}
  ogType="article"
  alternates={[
    { hreflang: "en", href: toAbsoluteUrl(getLanguagePartnerPath(entry)) },
    { hreflang: "ko", href: toAbsoluteUrl(getEntryPath(entry.data.kind, entry.data.id, "ko")) },
  ]}
>
  <main class="site-shell site-shell-detail">
    <SiteHeader
      lang={lang}
      enHref={getLanguagePartnerPath(entry)}
      koHref={getEntryPath(entry.data.kind, entry.data.id, "ko")}
    />
    <a class="back-link" href={getIndexPath("method", lang)}>전체 Methods로 돌아가기</a>
    <ArticleHeader
      label={getPageLabel(entry.data.kind, lang)}
      title={entry.data.title}
      summary={entry.data.summary}
      facts={entry.data.facts}
    />
    <Content />
    <RelatedWork entries={related} lang={lang} />
    <div class="detail-return">
      <a class="back-link" href={getIndexPath("method", lang)}>전체 Methods로 돌아가기</a>
    </div>
    <SiteFooter text="데이터 시스템과 운영 문제를 다루는 케이스 스터디와 방법론을 한글과 영어로 정리한 포트폴리오입니다." />
  </main>
</BaseLayout>
