---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import MethodList from "../../components/MethodList.astro";
import { SITE_FOOTER } from "../../data/site";
import { getEntries } from "../../lib/content";
import { getIndexPath, toAbsoluteUrl } from "../../lib/routes";

const lang = "en";
const entries = await getEntries("methods", lang);
---

<BaseLayout
  lang={lang}
  title="Methods | Yongjip Kim"
  description="Short notes on planning models and practical methods used in analytics and operations work."
  canonical={toAbsoluteUrl(getIndexPath("method", lang))}
  ogTitle="Methods | Yongjip Kim"
  ogDescription="Short notes on planning models and practical methods used in analytics and operations work."
  alternates={[
    { hreflang: "en", href: toAbsoluteUrl("/methods/") },
    { hreflang: "ko", href: toAbsoluteUrl("/ko/methods/") },
  ]}
>
  <main id="main-content" class="site-shell site-shell-home archive-page archive-page-methods">
    <SiteHeader lang={lang} enHref="/methods/" koHref="/ko/methods/" />
    <section class="hero hero-home hero-compact">
      <p class="eyebrow">Methods</p>
      <h1>Short notes on planning logic and operational methods</h1>
      <p class="hero-copy">Methods that support the case studies without trying to replace them.</p>
    </section>

    <section class="section section-list section-methods">
      <MethodList entries={entries} />
    </section>
    <SiteFooter text={SITE_FOOTER[lang]} />
  </main>
</BaseLayout>
