---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getEntries } from "../../lib/content";
import { getEntryPath, getIndexPath, toAbsoluteUrl } from "../../lib/routes";

const lang = "en";
const entries = await getEntries("methods", lang);
---

<BaseLayout
  lang={lang}
  title="Methods | Yongjip Kim"
  description="Short notes on planning models and practical methods used in analytics and operations work."
  canonical={toAbsoluteUrl(getIndexPath("method", lang))}
  ogTitle="Methods | Yongjip Kim"
  ogDescription="Short notes on planning models and practical methods used in analytics and operations work."
  alternates={[
    { hreflang: "en", href: toAbsoluteUrl("/methods/") },
    { hreflang: "ko", href: toAbsoluteUrl("/ko/methods/") },
  ]}
>
  <main class="site-shell site-shell-home archive-page archive-page-methods">
    <SiteHeader lang={lang} enHref="/methods/" koHref="/ko/methods/" />
    <section class="hero hero-home hero-compact">
      <p class="eyebrow">Methods</p>
      <h1>Short notes on practical models and planning methods.</h1>
      <p class="hero-copy">Supporting notes for operations and analytics work, kept shorter and quieter than the case studies.</p>
    </section>

    <section class="section section-list section-methods">
      <div class="method-list">
        {entries.map((entry) => (
          <article class="method-item">
            <p class="method-kicker">Method note</p>
            <a class="method-link" href={getEntryPath(entry.data.kind, entry.data.id, entry.data.lang)}>
              {entry.data.shortTitle}
            </a>
            <p class="method-summary">{entry.data.description}</p>
            <p class="method-meta">{`Planning use: ${entry.data.planningUse}`}</p>
            <a class="text-link method-cta" href={getEntryPath(entry.data.kind, entry.data.id, entry.data.lang)}>
              Read the method note
            </a>
          </article>
        ))}
      </div>
    </section>
    <SiteFooter text="A bilingual portfolio of case studies and methods for data systems and operations work." />
  </main>
</BaseLayout>
